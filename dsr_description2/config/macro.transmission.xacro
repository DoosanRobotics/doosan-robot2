<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    DSR Transmission (ROS2 Control Style)
    - ROS1의 transmission_interface/SimpleTransmission 제거
    - 각 joint에 ros2_control command/state_interface 명시
    - hardware_interface::SystemInterface(DRHWInterface)와 직접 매핑
  -->

  <xacro:macro name="dsr_transmission">
    
    <!-- Joint1 -->
    <joint name="joint1" type="revolute">
      <ros2_control>
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </ros2_control>
    </joint>

    <!-- Joint2 -->
    <joint name="joint2" type="revolute">
      <ros2_control>
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </ros2_control>
    </joint>

    <!-- Joint3 -->
    <joint name="joint3" type="revolute">
      <ros2_control>
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </ros2_control>
    </joint>

    <!-- Joint4 -->
    <joint name="joint4" type="revolute">
      <ros2_control>
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </ros2_control>
    </joint>

    <!-- Joint5 -->
    <joint name="joint5" type="revolute">
      <ros2_control>
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </ros2_control>
    </joint>

    <!-- Joint6 -->
    <joint name="joint6" type="revolute">
      <ros2_control>
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </ros2_control>
    </joint>

  </xacro:macro>
</robot>
